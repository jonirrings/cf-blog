{
  "name": "@cf-blog/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./schema": {
      "import": "./src/schema.ts",
      "types": "./src/schema.ts"
    },
    "./client": {
      "import": "./src/client.ts",
      "types": "./src/client.ts"
    },
    "./seed": {
      "import": "./src/seed.ts",
      "types": "./src/seed.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply cf-blog-db --config ../../wrangler.toml",
    "db:migrate:local": "wrangler d1 migrations apply cf-blog-db --local --config ../../wrangler.dev.toml",
    "db:studio": "drizzle-kit studio",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "fmt": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.30.10"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "drizzle-kit": "^0.21.0",
    "typescript": "catalog:",
    "wrangler": "^4.87.0"
  }
}
