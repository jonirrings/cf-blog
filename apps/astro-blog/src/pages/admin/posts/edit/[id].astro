---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getLocaleFromRequest, getT } from '../../../../lib/i18n';
import RichTextEditor from '../../../../components/RichTextEditor';

export const prerender = false;

interface PostData {
  id: number;
  title: string;
  slug: string;
  excerpt: string;
  content: string;
  framework: 'next' | 'nuxt' | 'svelte' | 'astro' | 'solid';
  status: 'draft' | 'published';
}

const locale = getLocaleFromRequest(Astro.request);
const t = getT(locale);

// 从 URL 获取文章 ID
const postId = Astro.params.id;
let post: PostData | null = null;
let editorContentJson = '';

try {
  const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8788';
  const res = await fetch(`${apiUrl}/api/posts/${postId}`);
  if (res.ok) {
    const data = await res.json();
    post = data.data || null;
    // Parse content as JSON for the editor
    if (post?.content) {
      try {
        const parsed = JSON.parse(post.content);
        editorContentJson = JSON.stringify(parsed);
      } catch {
        editorContentJson = JSON.stringify({
          type: 'doc',
          content: [{ type: 'paragraph', content: [{ type: 'text', text: post.content }] }],
        });
      }
    }
  }
} catch (err) {
  console.error('Failed to load post:', err);
}

// i18n values for client-side script
const i18nValues = {
  post: {
    updateFailed: t('post.updateFailed'),
  },
};
---

<AdminLayout title={t('post.editPost')}>
  <div>
    <h1 class="text-2xl font-bold text-gray-900 mb-6">{t('post.editPost')}</h1>

    <form id="edit-post-form" class="space-y-6">
      <div class="bg-white rounded-lg shadow p-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{t('post.title')}</label>
          <input
            type="text"
            id="title"
            name="title"
            value={post?.title || ''}
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
            required
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{t('post.slug')}</label>
          <input
            type="text"
            id="slug"
            name="slug"
            value={post?.slug || ''}
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
            required
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{t('post.excerpt')}</label>
          <textarea
            id="excerpt"
            name="excerpt"
            rows="2"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
          >{post?.excerpt || ''}</textarea>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{t('post.framework')}</label>
            <select
              id="framework"
              name="framework"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
            >
              <option value="next" selected={post?.framework === 'next'}>{t('framework.next')}</option>
              <option value="nuxt" selected={post?.framework === 'nuxt'}>{t('framework.nuxt')}</option>
              <option value="svelte" selected={post?.framework === 'svelte'}>{t('framework.svelte')}</option>
              <option value="astro" selected={post?.framework === 'astro'}>{t('framework.astro')}</option>
              <option value="solid" selected={post?.framework === 'solid'}>{t('framework.solid')}</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{t('post.status')}</label>
            <select
              id="status"
              name="status"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
            >
              <option value="draft" selected={post?.status === 'draft'}>{t('post.status.draft')}</option>
              <option value="published" selected={post?.status === 'published'}>{t('post.status.published')}</option>
            </select>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-6">
        <label class="block text-sm font-medium text-gray-700 mb-2">{t('post.content')}</label>
        <RichTextEditor
          client:only="react"
          initialContent={JSON.parse(editorContentJson || '{}')}
          placeholder={t('post.contentPlaceholder')}
        />
        <p class="text-xs text-gray-500 mt-1">{t('post.editorTip')}</p>
      </div>

      <div class="flex gap-4">
        <button
          type="submit"
          id="submit-btn"
          class="px-6 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 disabled:opacity-50"
        >
          {t('common.save')}
        </button>
        <a
          href="/astro/admin/posts"
          class="px-6 py-2 bg-gray-100 text-gray-700 rounded-lg font-medium hover:bg-gray-200"
        >
          {t('common.cancel')}
        </a>
      </div>
    </form>
  </div>

  <script define:vars={{ i18n: i18nValues }}>
    // 自动生成 slug
    const titleInput = document.getElementById('title');
    const slugInput = document.getElementById('slug');

    titleInput?.addEventListener('input', () => {
      const slug = titleInput.value
        .toLowerCase()
        .replace(/[^a-z0-9\u4e00-\u9fa5\s-]/g, '')
        .replace(/[\s-]+/g, '-')
        .trim();
      slugInput.value = slug;
    });

    // 表单提交
    const form = document.getElementById('edit-post-form');
    const submitBtn = document.getElementById('submit-btn');
    const postId = window.location.pathname.split('/').pop();

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitBtn) submitBtn.disabled = true;

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const apiBaseUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8788';
        const res = await fetch(`${apiBaseUrl}/api/posts/${postId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          window.location.href = '/astro/admin/posts';
        } else {
          const error = await res.json();
          alert(`${i18n.post.updateFailed}: ${error.message || ''}`);
        }
      } catch (err) {
        console.error('Update post failed:', err);
        alert(i18n.post.updateFailed);
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  </script>
</AdminLayout>
