---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getLocaleFromRequest, getT } from '../../lib/i18n';

export const prerender = false;

const locale = getLocaleFromRequest(Astro.request);
const t = getT(locale);

// i18n values for client-side script
const i18nValues = {
  settings: {
    saved: t('settings.saved'),
    saveFailed: t('form.error'),
  },
  common: {
    loading: t('common.loading'),
    save: t('common.save'),
  },
};
---

<AdminLayout title={t('admin.settings')}>
  <div>
    <h1 class="text-2xl font-bold text-gray-900 mb-6">{t('admin.settings')}</h1>

    <form id="settings-form" class="space-y-6">
      <!-- save message -->
      <div id="save-message" class="bg-green-50 text-green-700 p-4 rounded-lg" style="display: none;">
        {t('settings.saved')}
      </div>

      <!-- basic info -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">{t('settings.basicInfo')}</h2>

        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{t('settings.siteTitle')}</label>
            <input type="text" id="cfg-title" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{t('settings.siteDesc')}</label>
            <textarea id="cfg-desc" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500"></textarea>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{t('settings.logoUrl')}</label>
            <input type="url" id="cfg-logo" placeholder="https://example.com/logo.png" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{t('settings.footerText')}</label>
            <input type="text" id="cfg-footer" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500" />
          </div>
        </div>
      </div>

      <!-- feature toggles -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">{t('settings.featureToggles')}</h2>

        <div class="space-y-4">
          <label class="flex items-center justify-between">
            <span class="text-sm font-medium text-gray-700">{t('settings.enableComments')}</span>
            <input type="checkbox" id="cfg-comments" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" />
          </label>

          <label class="flex items-center justify-between">
            <span class="text-sm font-medium text-gray-700">{t('settings.enableAnalytics')}</span>
            <input type="checkbox" id="cfg-analytics" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" />
          </label>
        </div>
      </div>

      <!-- save button -->
      <div class="flex justify-end">
        <button type="submit" id="save-btn" class="px-6 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed">
          {t('common.save')}
        </button>
      </div>
    </form>
  </div>

  <script define:i18n={i18nValues}>
    interface SiteConfig {
      title: string;
      description: string;
      logo: string;
      footerText: string;
      enableComments: boolean;
      enableAnalytics: boolean;
    }

    let config: SiteConfig = {
      title: '',
      description: '',
      logo: '',
      footerText: '',
      enableComments: true,
      enableAnalytics: true,
    };

    // Load config on mount
    async function fetchConfig() {
      try {
        const apiBaseUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8788';
        const res = await fetch(`${apiBaseUrl}/api/config/site`);
        const data = await res.json();
        if (data.data) {
          config = { ...config, ...data.data };
          // Populate form
          (document.getElementById('cfg-title') as HTMLInputElement).value = config.title;
          (document.getElementById('cfg-desc') as HTMLTextAreaElement).value = config.description;
          (document.getElementById('cfg-logo') as HTMLInputElement).value = config.logo;
          (document.getElementById('cfg-footer') as HTMLInputElement).value = config.footerText;
          (document.getElementById('cfg-comments') as HTMLInputElement).checked = config.enableComments;
          (document.getElementById('cfg-analytics') as HTMLInputElement).checked = config.enableAnalytics;
        }
      } catch (err) {
        console.error('Failed to fetch config:', err);
      }
    }

    async function handleSubmit(e: Event) {
      e.preventDefault();
      const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
      const saveMessage = document.getElementById('save-message');

      saveBtn.disabled = true;
      saveBtn.textContent = i18n.common.loading;
      if (saveMessage) saveMessage.style.display = 'none';

      // Gather form data
      config.title = (document.getElementById('cfg-title') as HTMLInputElement).value;
      config.description = (document.getElementById('cfg-desc') as HTMLTextAreaElement).value;
      config.logo = (document.getElementById('cfg-logo') as HTMLInputElement).value;
      config.footerText = (document.getElementById('cfg-footer') as HTMLInputElement).value;
      config.enableComments = (document.getElementById('cfg-comments') as HTMLInputElement).checked;
      config.enableAnalytics = (document.getElementById('cfg-analytics') as HTMLInputElement).checked;

      try {
        const apiBaseUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8788';
        const res = await fetch(`${apiBaseUrl}/api/config/site`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(config),
        });
        if (res.ok) {
          if (saveMessage) saveMessage.style.display = 'block';
          setTimeout(() => { if (saveMessage) saveMessage.style.display = 'none'; }, 3000);
        } else {
          alert(i18n.settings.saveFailed);
        }
      } catch (err) {
        console.error('Save failed:', err);
        alert(i18n.settings.saveFailed);
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = i18n.common.save;
      }
    }

    document.getElementById('settings-form')?.addEventListener('submit', handleSubmit);
    fetchConfig();
  </script>
</AdminLayout>
