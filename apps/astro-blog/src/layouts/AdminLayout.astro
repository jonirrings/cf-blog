---
import { getLocaleFromRequest, getT } from '../lib/i18n';
import { supportedLocales } from '@cf-blog/i18n';

export const prerender = false;

interface Props {
  title?: string;
}

const { title } = Astro.props;

const locale = getLocaleFromRequest(Astro.request);
const t = getT(locale);

// Server-side auth check
let session: { userName?: string; userRole?: string; userEmail?: string } | null = null;
try {
  const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8788';
  const res = await fetch(`${apiUrl}/api/auth/session`, {
    headers: { cookie: Astro.request.headers.get('cookie') || '' },
  });
  const data = await res.json();
  if (data.success && data.session) {
    session = data.session;
  }
} catch (err) {
  console.error('Failed to fetch session:', err);
}

if (!session || session.userRole !== 'admin') {
  return Astro.redirect('/astro/auth/login');
}

const navItems = [
  { href: '/astro/admin/dashboard', label: t('admin.dashboard'), icon: 'dashboard' },
  { href: '/astro/admin/posts', label: t('admin.posts'), icon: 'posts' },
  { href: '/astro/admin/comments', label: t('admin.comments'), icon: 'comments' },
  { href: '/astro/admin/users', label: t('admin.users'), icon: 'users' },
  { href: '/astro/admin/settings', label: t('admin.settings'), icon: 'settings' },
];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={title || t('admin.title')} />
    <title>{title || t('admin.title')}</title>
  </head>
  <body class="min-h-screen bg-gray-100">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-white shadow-lg fixed h-full flex flex-col">
        <div class="p-6 border-b">
          <h2 class="text-xl font-bold text-gray-900">{t('admin.title')}</h2>
          <a href="/astro/" class="text-sm text-blue-600 hover:underline">{t('admin.backToBlog')}</a>
        </div>

        <nav class="flex-1 p-4 space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'block px-4 py-2 rounded-lg text-sm font-medium transition-colors',
                Astro.url.pathname === item.href
                  ? 'bg-blue-50 text-blue-700'
                  : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900',
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <!-- Language Switcher -->
        <div class="p-4 border-t">
          <label class="block text-xs text-gray-500 mb-1">Language</label>
          <select
            onchange="document.cookie=`locale=${this.value}; max-age=31536000; path=/`; location.reload()"
            class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm"
          >
            {supportedLocales.map((loc) => (
              <option value={loc.code} selected={loc.code === locale}>
                {loc.flag} {loc.name}
              </option>
            ))}
          </select>
        </div>

        <!-- User info -->
        <div class="p-4 border-t">
          <p class="font-medium text-gray-900">{session?.userName}</p>
          <p class="text-sm text-gray-500">{t(`user.role.${session?.userRole}`)}</p>
        </div>
      </aside>

      <!-- Main content -->
      <main class="ml-64 flex-1 p-6">
        <slot />
      </main>
    </div>
  </body>
</html>
