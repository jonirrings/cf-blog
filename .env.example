# Cloudflare 环境变量配置
# 复制此文件为 .dev.vars (本地开发) 或在 GitHub Secrets 中配置 (生产部署)

# ==================== 基础配置 ====================
ENVIRONMENT=development
SITE_URL=http://localhost:8788

# ==================== GitHub OAuth ====================
# 在 GitHub Developer Settings 中创建 OAuth App
# https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ==================== Turnstile (人机验证) ====================
# 在 Cloudflare Dashboard 创建 Turnstile 站点
# https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ==================== Passkey 认证 ====================
# Passkey 配置 (可选)
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=CF Blog Local

# ==================== JWT 配置 ====================
# 用于会话管理的 JWT 密钥
JWT_SECRET=your_jwt_secret_min_32_characters_long

# ==================== D1 数据库 ====================
# 运行 wrangler d1 create cf-blog-db 创建数据库
D1_DATABASE_ID=your_database_id

# ==================== KV 命名空间 ====================
# 运行 wrangler kv:namespace create CONFIG_KV 等创建
CONFIG_KV_ID=your_config_kv_id
CACHE_KV_ID=your_cache_kv_id
USER_KV_ID=your_user_kv_id

# ==================== R2 存储桶 ====================
# 运行 wrangler r2 bucket create cf-blog-images 创建
IMAGES_R2_BUCKET=cf-blog-images

# ==================== 可选配置 ====================
# 日志级别
LOG_LEVEL=info

# 速率限制 (请求数/分钟)
RATE_LIMIT=60

# 是否启用调试模式
DEBUG=false
